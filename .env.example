# Customer Success FTE - Environment Configuration
# Copy this file to .env and fill in your actual credentials

# =============================================================================
# GROK AI CONFIGURATION (xAI)
# =============================================================================
# Get your Grok API key from: https://console.x.ai
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-beta
GROK_BASE_URL=https://api.x.ai/v1
GROK_MAX_TOKENS=4096
GROK_TEMPERATURE=0.7

# =============================================================================
# TWILIO WHATSAPP CONFIGURATION
# =============================================================================
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG_MODE=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================
GMAIL_ENABLED=true
WHATSAPP_ENABLED=true
WEBFORM_ENABLED=true

# =============================================================================
# CORS SETTINGS
# =============================================================================
WEBFORM_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# DATABASE (Optional - for future use)
# =============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/customer_success
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# NOTES
# =============================================================================
# 1. Gmail credentials are stored in credentials/gmail_credentials.json
# 2. Gmail token is auto-generated in credentials/gmail_token.pickle
# 3. For WhatsApp, you need a Twilio account with WhatsApp enabled
# 4. Your Grok API key is already configured and ready to use
